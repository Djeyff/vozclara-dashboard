{
  "buildCommand": "mkdir -p dist && cp -r app public index.html dist/",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/app/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://dashboard-api.voz-clara.com/api/:path*" }
  ]
}
